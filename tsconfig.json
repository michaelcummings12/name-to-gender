{
  "compilerOptions": {
    "target": "es2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2025"],
    "declaration": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": ["src", "scripts", "test"]
}
