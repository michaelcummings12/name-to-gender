{
  "name": "name-to-gender",
  "version": "1.0.1",
  "description": "Guess gender from a first name using US Social Security data. Returns a probability and the raw birth counts. TypeScript, ESM + CJS, zero dependencies.",
  "homepage": "https://github.com/michaelcummings12/name-to-gender#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:data": "tsx scripts/build-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gender",
    "gender detection",
    "gender guess",
    "gender prediction",
    "guess gender",
    "name to gender",
    "name gender",
    "first name",
    "first name gender",
    "infer gender",
    "predict gender",
    "detect gender",
    "sex",
    "male",
    "female",
    "names",
    "baby names",
    "ssa",
    "social security",
    "census",
    "demographics",
    "typescript"
  ],
  "author": "Michael Cummings (https://www.michaelcummin.gs)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelcummings12/name-to-gender.git"
  },
  "bugs": {
    "url": "https://github.com/michaelcummings12/name-to-gender/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true
  }
}
